# ========================================
# START DIGITAL - ENVIRONMENT VARIABLES
# ========================================
# Copy file ini menjadi .env dan isi dengan nilai yang benar
# JANGAN PERNAH commit file .env ke GitHub!
# ========================================

# Database - Supabase PostgreSQL
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
# Dapatkan dari: Supabase Dashboard → Settings → Database → Connection string
DATABASE_URL=

# Admin Panel Access
# Passphrase untuk login ke /admin (ganti dengan passphrase kuat Anda)
ADMIN_PASSPHRASE=

# Midtrans Payment Gateway (Sandbox untuk testing)
# Dapatkan dari: https://dashboard.sandbox.midtrans.com/settings/access-keys
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Node Environment
NODE_ENV=development
